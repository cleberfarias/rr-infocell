{
  "name": "rr-infocell-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:emulator": "node --env-file=.env.emulator --watch --import=tsx/esm src/server.ts",
    "dev:full": "concurrently --names \"back,front\" --prefix-colors \"cyan,magenta\" \"npm run dev:emulator\" \"npm run dev --prefix ../frontend\"",
    "auth:set-role": "tsx src/scripts/set-user-role.ts",
    "script:normalizar-telefones": "tsx src/scripts/normalizar-telefones.ts",
    "script:limpar-conversas": "tsx src/scripts/limpar-conversas-invalidas.ts",
    "script:migrar-9digito": "tsx src/scripts/migrar-conversa-9digito.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.0.2",
    "nodemailer": "^8.0.10",
    "openai": "^6.37.0",
    "qrcode": "^1.5.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.16.5",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.32.0",
    "globals": "^15.15.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  }
}
