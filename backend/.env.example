NODE_ENV=development
PORT=3333
CORS_ORIGIN=http://127.0.0.1:5173

FIREBASE_PROJECT_ID=rr-infocell
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Local emulators, optional.
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8081
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Atendimento WhatsApp automations.
WHATSAPP_AUTH_DIR=./whatsapp-auth
ATENDIMENTO_PIX_CHAVE=
ATENDIMENTO_PIX_NOME=
ATENDIMENTO_LEMBRETE_ORCAMENTO_HORAS=24
ATENDIMENTO_LEMBRETE_RETIRADA_DIAS=2
ATENDIMENTO_AUTOARQUIVAR_DIAS=7

# Chave mestra (min. 32 caracteres) para credenciais fiscais e de pagamentos.
# Em producao, forneca pelo Secret Manager; nunca versione o valor real.
INTEGRATIONS_ENCRYPTION_KEY=

# Aplicacao OAuth da plataforma NextAssist no Mercado Pago.
MERCADO_PAGO_CLIENT_ID=
MERCADO_PAGO_CLIENT_SECRET=
MERCADO_PAGO_OAUTH_REDIRECT_URI=http://localhost:3333/api/integracoes/mercado-pago/oauth/callback
