# Copie este arquivo para .env.staging e preencha apenas valores de staging.
# Nunca use secrets reais de producao neste arquivo.
VITE_APP_ENV=staging
VITE_API_BASE_URL=https://staging-api.example.com/api
VITE_AUTH_DEV_MODE=false

VITE_TENANT_ID=rr-infocell
VITE_PRODUCT_NAME=NextAssist
VITE_DEFAULT_PLAN=premium
VITE_ENABLE_TENANT_CONTEXT=true

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=rr-infocell-staging.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=rr-infocell-staging
VITE_FIREBASE_STORAGE_BUCKET=rr-infocell-staging.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
