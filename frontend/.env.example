# Copie este arquivo para .env e preencha os valores
VITE_APP_ENV=development
VITE_API_BASE_URL=http://localhost:3333/api
VITE_AUTH_DEV_MODE=true

# Identidade do tenant (branding white-label)
# VITE_TENANT_ID=rr-infocell
# VITE_PRODUCT_NAME=NextAssist
# VITE_SYSTEM_NAME=RR Infocell
# VITE_TENANT_NAME=RR Infocell
# VITE_LOGO_URL=           # URL externa da logo; se vazio usa logo-rrinfocell.png

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=rr-infocell.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=rr-infocell
VITE_FIREBASE_STORAGE_BUCKET=rr-infocell.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
