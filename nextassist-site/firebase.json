{
  "hosting": {
    "site": "nextassist-site",
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "nextassist-site",
          "region": "southamerica-east1"
        }
      }
    ]
  }
}
