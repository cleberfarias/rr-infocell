rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    function isOperationalUser() {
      return isSignedIn()
        && request.auth.token.role in ["admin", "atendente", "tecnico"];
    }

    function isAllowedImage() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    match /ordensServico/{ordemId}/{fileName} {
      allow read: if isOperationalUser();
      allow write: if isOperationalUser() && isAllowedImage();
    }

    match /comprovantes/{ordemId}/{fileName} {
      allow read: if isOperationalUser();
      allow write: if hasRole("admin") || hasRole("atendente");
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
