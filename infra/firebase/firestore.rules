rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole("admin");
    }

    function isOperationalUser() {
      return isSignedIn()
        && request.auth.token.role in ["admin", "atendente", "tecnico"];
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /clientes/{clienteId} {
      allow read: if isOperationalUser();
      allow write: if isAdmin() || hasRole("atendente");
    }

    match /aparelhos/{aparelhoId} {
      allow read: if isOperationalUser();
      allow write: if isAdmin() || hasRole("atendente");
    }

    match /ordensServico/{ordemId} {
      allow read: if isOperationalUser();
      allow create: if isAdmin() || hasRole("atendente");
      allow update: if isOperationalUser();
      allow delete: if isAdmin();
    }

    match /checklists/{checklistId} {
      allow read: if isOperationalUser();
      allow write: if isAdmin() || hasRole("tecnico");
    }

    match /produtos/{produtoId} {
      allow read: if isOperationalUser();
      allow write: if isAdmin();
    }

    match /vendas/{vendaId} {
      allow read, write: if isAdmin();
    }

    match /movimentacoesEstoque/{movimentacaoId} {
      allow read: if isOperationalUser();
      allow write: if isAdmin();
    }

    match /auditLogs/{auditLogId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /counters/{counterId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
